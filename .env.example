# Local container infrastructure. Replace every change-me value in `.env`.
POSTGRES_USER=piki
POSTGRES_DB=piki
POSTGRES_PASSWORD=change-me-local-postgres
N8N_DB_PASSWORD=change-me-local-n8n-db
N8N_ENCRYPTION_KEY=change-me-with-openssl-rand-hex-32
PIKI_API_PORT=8000
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
N8N_WEBHOOK_URL=http://localhost:5678
GENERIC_TIMEZONE=America/Argentina/Buenos_Aires

# Production may mount the complete SQLAlchemy URL as a Docker secret.
PIKI_DATABASE_URL_FILE=
PIKI_ACTIVE_PICK_TTL_SECONDS=1800
PIKI_CONVERSATION_LOCK_TTL_SECONDS=30
PIKI_MESSAGE_DEDUP_TTL_SECONDS=604800
PIKI_PENDING_ACTION_TTL_SECONDS=900

# Stage 3: BuenPick Internal API. Production access requires explicit opt-in.
PIKI_BUENPICK_INTERNAL_API_BASE_URL=https://api.buenpick.com.ar/internal/v1
PIKI_BUENPICK_INTERNAL_API_TOKEN=replace-with-internal-api-token
PIKI_BUENPICK_INTERNAL_API_TOKEN_FILE=
# Local ignored override may mount secrets/buenpick_internal_api_token.txt.
PIKI_BUENPICK_TIMEOUT_SECONDS=5
PIKI_BUENPICK_MAX_ATTEMPTS=3
PIKI_BUENPICK_ALLOW_PRODUCTION=false

# Stage 6: Meta WhatsApp Cloud API. Never commit real values.
PIKI_META_APP_ID=
PIKI_META_APP_SECRET=
PIKI_META_APP_SECRET_FILE=
PIKI_META_WABA_ID=
PIKI_META_PHONE_NUMBER_ID=
PIKI_META_ACCESS_TOKEN=
PIKI_META_ACCESS_TOKEN_FILE=
PIKI_META_WEBHOOK_VERIFY_TOKEN=
PIKI_META_WEBHOOK_VERIFY_TOKEN_FILE=
PIKI_META_GRAPH_API_VERSION=
PIKI_META_GRAPH_BASE_URL=https://graph.facebook.com
PIKI_META_DELIVERY_TIMEOUT_SECONDS=10
PIKI_META_INGRESS_ENABLED=false

# Stage 5: LLM adapter. Select the model explicitly; no default incurs API usage.
PIKI_LLM_PROVIDER=openai
PIKI_LLM_MODEL=replace-with-approved-model-id
PIKI_LLM_API_KEY=replace-with-provider-api-key
PIKI_LLM_API_KEY_FILE=
PIKI_LLM_BASE_URL=https://api.openai.com/v1
PIKI_LLM_TIMEOUT_SECONDS=15
PIKI_LLM_MAX_ATTEMPTS=2
PIKI_LLM_MAX_OUTPUT_TOKENS=500

# Conversation runtime and the same-origin local console are explicit opt-ins.
PIKI_CONVERSATION_ENABLED=false
PIKI_CONVERSATION_WORKER_ENABLED=false
PIKI_CONVERSATION_WORKER_POLL_SECONDS=1
PIKI_CONVERSATION_WORKER_CLAIM_TIMEOUT_SECONDS=120
PIKI_CONVERSATION_WORKER_MAX_ATTEMPTS=3
PIKI_LOCAL_CONSOLE_ENABLED=false
